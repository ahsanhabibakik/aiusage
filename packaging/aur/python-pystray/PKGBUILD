# Not yet submitted to the AUR -- prerequisite for the aiusage-tracker
# PKGBUILD, since pystray has no AUR package of its own.
pkgname=python-pystray
pkgver=0.19.5
pkgrel=1
pkgdesc="Cross-platform system tray icon library"
arch=('any')
url="https://github.com/moses-palmer/pystray"
license=('LGPL3')
depends=('python' 'python-pillow' 'python-six' 'python-xlib')
makedepends=('python-installer' 'python-wheel')
source=("https://files.pythonhosted.org/packages/5c/64/927a4b9024196a4799eba0180e0ca31568426f258a4a5c90f87a97f51d28/pystray-${pkgver}-py2.py3-none-any.whl")
sha256sums=('a0c2229d02cf87207297c22d86ffc57c86c227517b038c0d3c59df79295ac617')

package() {
    python -m installer --destdir="$pkgdir" "pystray-${pkgver}-py2.py3-none-any.whl"
}
